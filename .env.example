# MedLocator Environment Variables
# Copy this to .env and fill in your actual values

# ============================================
# DATABASE (Supabase Postgres)
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_supabase_db_password

# ============================================
# KAFKA (Aiven Free Tier)
# ============================================
SPRING_KAFKA_BOOTSTRAP_SERVERS=your-kafka-service-name.aivencloud.com:12330
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="avnadmin" password="YOUR_AIVEN_PASSWORD";

# ============================================
# SECURITY
# ============================================
JWT_SECRET=generate_a_long_random_string_at_least_32_characters
ALLOWED_ORIGINS=https://your-app.vercel.app

# ============================================
# AI SERVICES
# ============================================
GROQ_API_KEY=gsk_your_groq_key
OPENROUTER_API_KEY=sk-or-your_openrouter_key
GOOGLE_PLACES_API_KEY=AIzaSy_your_google_key

# ============================================
# STORAGE (Supabase)
# ============================================
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_BUCKET=medical-reports

# ============================================
# EMAIL (Gmail SMTP)
# ============================================
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_app_specific_password

# ============================================
# DATA SEEDING (Set to 'always' for first deploy, then 'never')
# ============================================
SQL_INIT_MODE=always
